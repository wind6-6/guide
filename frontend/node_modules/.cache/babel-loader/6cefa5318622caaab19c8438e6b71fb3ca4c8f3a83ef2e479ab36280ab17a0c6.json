{"ast":null,"code":"export default {\n  name: 'PlaceQueryView',\n  data() {\n    return {\n      searchForm: {\n        keyword: '',\n        type: ''\n      },\n      facilityList: []\n    };\n  },\n  mounted() {\n    this.getFacilities();\n  },\n  methods: {\n    async getFacilities() {\n      try {\n        // 这里应该调用后端API，现在使用模拟数据\n        this.facilityList = [{\n          id: 1,\n          name: '中餐厅',\n          type: 'restaurant',\n          location: '景区中心',\n          description: '提供各种中式美食'\n        }, {\n          id: 2,\n          name: '公共厕所',\n          type: 'toilet',\n          location: '景区入口',\n          description: '干净整洁的公共厕所'\n        }, {\n          id: 3,\n          name: '纪念品商店',\n          type: 'shop',\n          location: '景区出口',\n          description: '出售各种纪念品'\n        }];\n      } catch (error) {\n        console.error('获取设施列表失败:', error);\n      }\n    },\n    async handleSearch() {\n      try {\n        // 这里应该调用后端API，现在使用模拟数据\n        this.facilityList = [{\n          id: 1,\n          name: '中餐厅',\n          type: 'restaurant',\n          location: '景区中心',\n          description: '提供各种中式美食'\n        }];\n      } catch (error) {\n        console.error('搜索失败:', error);\n      }\n    },\n    getTypeName(type) {\n      const typeMap = {\n        'restaurant': '餐厅',\n        'toilet': '厕所',\n        'shop': '商店',\n        'medical': '医疗'\n      };\n      return typeMap[type] || type;\n    }\n  }\n};","map":{"version":3,"names":["name","data","searchForm","keyword","type","facilityList","mounted","getFacilities","methods","id","location","description","error","console","handleSearch","getTypeName","typeMap"],"sources":["D:\\Program Files (x86)\\Trae CN\\new file\\guide\\frontend\\src\\pages\\PlaceQuery\\PlaceQueryView.vue"],"sourcesContent":["<template>\r\n  <div class=\"place-query-container\">\r\n    <el-card shadow=\"hover\" class=\"search-card\">\r\n      <template #header>\r\n        <div class=\"card-header\">\r\n          <span>场所查询</span>\r\n        </div>\r\n      </template>\r\n      <el-form :inline=\"true\" :model=\"searchForm\" class=\"search-form\">\r\n        <el-form-item label=\"关键词\">\r\n          <el-input v-model=\"searchForm.keyword\" placeholder=\"请输入关键词\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"类型\">\r\n          <el-select v-model=\"searchForm.type\" placeholder=\"选择类型\">\r\n            <el-option label=\"全部\" value=\"\"></el-option>\r\n            <el-option label=\"餐厅\" value=\"restaurant\"></el-option>\r\n            <el-option label=\"厕所\" value=\"toilet\"></el-option>\r\n            <el-option label=\"商店\" value=\"shop\"></el-option>\r\n            <el-option label=\"医疗\" value=\"medical\"></el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n        <el-form-item>\r\n          <el-button type=\"primary\" @click=\"handleSearch\">搜索</el-button>\r\n        </el-form-item>\r\n      </el-form>\r\n    </el-card>\r\n\r\n    <div class=\"facility-list\">\r\n      <el-card\r\n        v-for=\"facility in facilityList\"\r\n        :key=\"facility.id\"\r\n        shadow=\"hover\"\r\n        class=\"facility-card\"\r\n      >\r\n        <template #header>\r\n          <div class=\"facility-header\">\r\n            <span>{{ facility.name }}</span>\r\n            <span class=\"facility-type\">{{ getTypeName(facility.type) }}</span>\r\n          </div>\r\n        </template>\r\n        <div class=\"facility-content\">\r\n          <p>{{ facility.description }}</p>\r\n          <div class=\"facility-info\">\r\n            <span class=\"location\">位置: {{ facility.location }}</span>\r\n          </div>\r\n        </div>\r\n      </el-card>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'PlaceQueryView',\r\n  data() {\r\n    return {\r\n      searchForm: {\r\n        keyword: '',\r\n        type: ''\r\n      },\r\n      facilityList: []\r\n    }\r\n  },\r\n  mounted() {\r\n    this.getFacilities()\r\n  },\r\n  methods: {\r\n    async getFacilities() {\r\n      try {\r\n        // 这里应该调用后端API，现在使用模拟数据\r\n        this.facilityList = [\r\n          {\r\n            id: 1,\r\n            name: '中餐厅',\r\n            type: 'restaurant',\r\n            location: '景区中心',\r\n            description: '提供各种中式美食'\r\n          },\r\n          {\r\n            id: 2,\r\n            name: '公共厕所',\r\n            type: 'toilet',\r\n            location: '景区入口',\r\n            description: '干净整洁的公共厕所'\r\n          },\r\n          {\r\n            id: 3,\r\n            name: '纪念品商店',\r\n            type: 'shop',\r\n            location: '景区出口',\r\n            description: '出售各种纪念品'\r\n          }\r\n        ]\r\n      } catch (error) {\r\n        console.error('获取设施列表失败:', error)\r\n      }\r\n    },\r\n    async handleSearch() {\r\n      try {\r\n        // 这里应该调用后端API，现在使用模拟数据\r\n        this.facilityList = [\r\n          {\r\n            id: 1,\r\n            name: '中餐厅',\r\n            type: 'restaurant',\r\n            location: '景区中心',\r\n            description: '提供各种中式美食'\r\n          }\r\n        ]\r\n      } catch (error) {\r\n        console.error('搜索失败:', error)\r\n      }\r\n    },\r\n    getTypeName(type) {\r\n      const typeMap = {\r\n        'restaurant': '餐厅',\r\n        'toilet': '厕所',\r\n        'shop': '商店',\r\n        'medical': '医疗'\r\n      }\r\n      return typeMap[type] || type\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.place-query-container {\r\n  padding: 20px;\r\n}\r\n\r\n.search-card {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.search-form {\r\n  margin-top: 10px;\r\n}\r\n\r\n.facility-list {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));\r\n  gap: 20px;\r\n}\r\n\r\n.facility-card {\r\n  height: 100%;\r\n}\r\n\r\n.facility-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n}\r\n\r\n.facility-type {\r\n  background-color: #ecf5ff;\r\n  color: #409eff;\r\n  padding: 2px 8px;\r\n  border-radius: 4px;\r\n  font-size: 12px;\r\n}\r\n\r\n.facility-content {\r\n  margin-top: 10px;\r\n}\r\n\r\n.facility-info {\r\n  margin-top: 15px;\r\n  font-size: 14px;\r\n  color: #606266;\r\n}\r\n</style>"],"mappings":"AAoDA,eAAe;EACbA,IAAI,EAAE,gBAAgB;EACtBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,UAAU,EAAE;QACVC,OAAO,EAAE,EAAE;QACXC,IAAI,EAAE;MACR,CAAC;MACDC,YAAY,EAAE;IAChB;EACF,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,aAAa,CAAC;EACrB,CAAC;EACDC,OAAO,EAAE;IACP,MAAMD,aAAaA,CAAA,EAAG;MACpB,IAAI;QACF;QACA,IAAI,CAACF,YAAW,GAAI,CAClB;UACEI,EAAE,EAAE,CAAC;UACLT,IAAI,EAAE,KAAK;UACXI,IAAI,EAAE,YAAY;UAClBM,QAAQ,EAAE,MAAM;UAChBC,WAAW,EAAE;QACf,CAAC,EACD;UACEF,EAAE,EAAE,CAAC;UACLT,IAAI,EAAE,MAAM;UACZI,IAAI,EAAE,QAAQ;UACdM,QAAQ,EAAE,MAAM;UAChBC,WAAW,EAAE;QACf,CAAC,EACD;UACEF,EAAE,EAAE,CAAC;UACLT,IAAI,EAAE,OAAO;UACbI,IAAI,EAAE,MAAM;UACZM,QAAQ,EAAE,MAAM;UAChBC,WAAW,EAAE;QACf,EACF;MACF,EAAE,OAAOC,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,WAAW,EAAEA,KAAK;MAClC;IACF,CAAC;IACD,MAAME,YAAYA,CAAA,EAAG;MACnB,IAAI;QACF;QACA,IAAI,CAACT,YAAW,GAAI,CAClB;UACEI,EAAE,EAAE,CAAC;UACLT,IAAI,EAAE,KAAK;UACXI,IAAI,EAAE,YAAY;UAClBM,QAAQ,EAAE,MAAM;UAChBC,WAAW,EAAE;QACf,EACF;MACF,EAAE,OAAOC,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,OAAO,EAAEA,KAAK;MAC9B;IACF,CAAC;IACDG,WAAWA,CAACX,IAAI,EAAE;MAChB,MAAMY,OAAM,GAAI;QACd,YAAY,EAAE,IAAI;QAClB,QAAQ,EAAE,IAAI;QACd,MAAM,EAAE,IAAI;QACZ,SAAS,EAAE;MACb;MACA,OAAOA,OAAO,CAACZ,IAAI,KAAKA,IAAG;IAC7B;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}