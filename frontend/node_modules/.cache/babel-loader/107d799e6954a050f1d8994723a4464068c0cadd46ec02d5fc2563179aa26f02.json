{"ast":null,"code":"import { recommendApi } from '../../api/index.js';\nexport default {\n  name: 'RecommendView',\n  data() {\n    return {\n      searchForm: {\n        sortBy: 'rating',\n        category: ''\n      },\n      scenicList: []\n    };\n  },\n  mounted() {\n    this.getRecommendList();\n  },\n  methods: {\n    async getRecommendList() {\n      try {\n        const response = await recommendApi.getList();\n        this.scenicList = response.data;\n      } catch (error) {\n        console.error('获取推荐列表失败:', error);\n      }\n    },\n    async handleSearch() {\n      try {\n        const response = await recommendApi.getList(this.searchForm);\n        this.scenicList = response.data;\n      } catch (error) {\n        console.error('搜索失败:', error);\n      }\n    },\n    getCategoryName(category) {\n      const categoryMap = {\n        'natural': '自然景观',\n        'cultural': '人文景观',\n        'theme': '主题公园'\n      };\n      return categoryMap[category] || category;\n    }\n  }\n};","map":{"version":3,"names":["recommendApi","name","data","searchForm","sortBy","category","scenicList","mounted","getRecommendList","methods","response","getList","error","console","handleSearch","getCategoryName","categoryMap"],"sources":["E:\\北邮\\大二下\\数据结构\\project\\guide\\frontend\\src\\pages\\Recommend\\RecommendView.vue"],"sourcesContent":["<template>\r\n  <div class=\"recommend-container\">\r\n    <el-card shadow=\"hover\" class=\"search-card\">\r\n      <template #header>\r\n        <div class=\"card-header\">\r\n          <span>景点推荐</span>\r\n        </div>\r\n      </template>\r\n      <el-form :inline=\"true\" :model=\"searchForm\" class=\"search-form\">\r\n        <el-form-item label=\"排序方式\">\r\n          <el-select v-model=\"searchForm.sortBy\" placeholder=\"选择排序方式\">\r\n            <el-option label=\"按评分\" value=\"rating\"></el-option>\r\n            <el-option label=\"按热度\" value=\"hotness\"></el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n        <el-form-item label=\"类别\">\r\n          <el-select v-model=\"searchForm.category\" placeholder=\"选择类别\">\r\n            <el-option label=\"全部\" value=\"\"></el-option>\r\n            <el-option label=\"自然景观\" value=\"natural\"></el-option>\r\n            <el-option label=\"人文景观\" value=\"cultural\"></el-option>\r\n            <el-option label=\"主题公园\" value=\"theme\"></el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n        <el-form-item>\r\n          <el-button type=\"primary\" @click=\"handleSearch\">搜索</el-button>\r\n        </el-form-item>\r\n      </el-form>\r\n    </el-card>\r\n\r\n    <div class=\"scenic-list\">\r\n      <el-card\r\n        v-for=\"scenic in scenicList\"\r\n        :key=\"scenic.id\"\r\n        shadow=\"hover\"\r\n        class=\"scenic-card\"\r\n      >\r\n        <template #header>\r\n          <div class=\"scenic-header\">\r\n            <span>{{ scenic.name }}</span>\r\n            <div class=\"scenic-rating\">\r\n              <el-rate\r\n                v-model=\"scenic.rating\"\r\n                :max=\"5\"\r\n                disabled\r\n                show-score\r\n                score-template=\"{{ value }}\"\r\n              ></el-rate>\r\n            </div>\r\n          </div>\r\n        </template>\r\n        <div class=\"scenic-content\">\r\n          <p>{{ scenic.description }}</p>\r\n          <div class=\"scenic-info\">\r\n            <span class=\"hotness\">热度: {{ scenic.hotness }}</span>\r\n            <span class=\"category\">{{ getCategoryName(scenic.category) }}</span>\r\n          </div>\r\n        </div>\r\n      </el-card>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { recommendApi } from '../../api/index.js'\r\n\r\nexport default {\r\n  name: 'RecommendView',\r\n  data() {\r\n    return {\r\n      searchForm: {\r\n        sortBy: 'rating',\r\n        category: ''\r\n      },\r\n      scenicList: []\r\n    }\r\n  },\r\n  mounted() {\r\n    this.getRecommendList()\r\n  },\r\n  methods: {\r\n    async getRecommendList() {\r\n      try {\r\n        const response = await recommendApi.getList()\r\n        this.scenicList = response.data\r\n      } catch (error) {\r\n        console.error('获取推荐列表失败:', error)\r\n      }\r\n    },\r\n    async handleSearch() {\r\n      try {\r\n        const response = await recommendApi.getList(this.searchForm)\r\n        this.scenicList = response.data\r\n      } catch (error) {\r\n        console.error('搜索失败:', error)\r\n      }\r\n    },\r\n    getCategoryName(category) {\r\n      const categoryMap = {\r\n        'natural': '自然景观',\r\n        'cultural': '人文景观',\r\n        'theme': '主题公园'\r\n      }\r\n      return categoryMap[category] || category\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.recommend-container {\r\n  padding: 20px;\r\n}\r\n\r\n.search-card {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.card-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n}\r\n\r\n.search-form {\r\n  margin-top: 10px;\r\n}\r\n\r\n.scenic-list {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));\r\n  gap: 20px;\r\n}\r\n\r\n.scenic-card {\r\n  height: 100%;\r\n}\r\n\r\n.scenic-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n}\r\n\r\n.scenic-content {\r\n  margin-top: 10px;\r\n}\r\n\r\n.scenic-info {\r\n  margin-top: 15px;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  font-size: 14px;\r\n  color: #606266;\r\n}\r\n\r\n.hotness {\r\n  color: #f56c6c;\r\n}\r\n\r\n.category {\r\n  color: #409eff;\r\n}\r\n</style>"],"mappings":"AA+DA,SAASA,YAAW,QAAS,oBAAmB;AAEhD,eAAe;EACbC,IAAI,EAAE,eAAe;EACrBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,UAAU,EAAE;QACVC,MAAM,EAAE,QAAQ;QAChBC,QAAQ,EAAE;MACZ,CAAC;MACDC,UAAU,EAAE;IACd;EACF,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,gBAAgB,CAAC;EACxB,CAAC;EACDC,OAAO,EAAE;IACP,MAAMD,gBAAgBA,CAAA,EAAG;MACvB,IAAI;QACF,MAAME,QAAO,GAAI,MAAMV,YAAY,CAACW,OAAO,CAAC;QAC5C,IAAI,CAACL,UAAS,GAAII,QAAQ,CAACR,IAAG;MAChC,EAAE,OAAOU,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,WAAW,EAAEA,KAAK;MAClC;IACF,CAAC;IACD,MAAME,YAAYA,CAAA,EAAG;MACnB,IAAI;QACF,MAAMJ,QAAO,GAAI,MAAMV,YAAY,CAACW,OAAO,CAAC,IAAI,CAACR,UAAU;QAC3D,IAAI,CAACG,UAAS,GAAII,QAAQ,CAACR,IAAG;MAChC,EAAE,OAAOU,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,OAAO,EAAEA,KAAK;MAC9B;IACF,CAAC;IACDG,eAAeA,CAACV,QAAQ,EAAE;MACxB,MAAMW,WAAU,GAAI;QAClB,SAAS,EAAE,MAAM;QACjB,UAAU,EAAE,MAAM;QAClB,OAAO,EAAE;MACX;MACA,OAAOA,WAAW,CAACX,QAAQ,KAAKA,QAAO;IACzC;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}