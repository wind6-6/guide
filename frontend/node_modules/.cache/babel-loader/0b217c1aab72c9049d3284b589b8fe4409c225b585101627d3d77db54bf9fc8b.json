{"ast":null,"code":"export default {\n  name: 'FoodView',\n  data() {\n    return {\n      searchForm: {\n        cuisine: ''\n      },\n      foodList: []\n    };\n  },\n  mounted() {\n    this.getFoodList();\n  },\n  methods: {\n    async getFoodList() {\n      try {\n        // 这里应该调用后端API，现在使用模拟数据\n        this.foodList = [{\n          id: 1,\n          name: '麻婆豆腐',\n          description: '四川传统名菜，麻辣鲜香',\n          hotness: 90,\n          rating: 4.5,\n          cuisine: 'sichuan',\n          price: 38\n        }, {\n          id: 2,\n          name: '宫保鸡丁',\n          description: '经典川菜，酸甜可口',\n          hotness: 85,\n          rating: 4.3,\n          cuisine: 'sichuan',\n          price: 45\n        }, {\n          id: 3,\n          name: '糖醋里脊',\n          description: '酸甜可口，外酥里嫩',\n          hotness: 80,\n          rating: 4.2,\n          cuisine: 'shandong',\n          price: 58\n        }];\n      } catch (error) {\n        console.error('获取美食列表失败:', error);\n      }\n    },\n    async handleSearch() {\n      try {\n        // 这里应该调用后端API，现在使用模拟数据\n        this.foodList = [{\n          id: 1,\n          name: '麻婆豆腐',\n          description: '四川传统名菜，麻辣鲜香',\n          hotness: 90,\n          rating: 4.5,\n          cuisine: 'sichuan',\n          price: 38\n        }, {\n          id: 2,\n          name: '宫保鸡丁',\n          description: '经典川菜，酸甜可口',\n          hotness: 85,\n          rating: 4.3,\n          cuisine: 'sichuan',\n          price: 45\n        }];\n      } catch (error) {\n        console.error('搜索失败:', error);\n      }\n    },\n    getCuisineName(cuisine) {\n      const cuisineMap = {\n        'sichuan': '川菜',\n        'cantonese': '粤菜',\n        'shandong': '鲁菜',\n        'huaiyang': '淮扬菜'\n      };\n      return cuisineMap[cuisine] || cuisine;\n    }\n  }\n};","map":{"version":3,"names":["name","data","searchForm","cuisine","foodList","mounted","getFoodList","methods","id","description","hotness","rating","price","error","console","handleSearch","getCuisineName","cuisineMap"],"sources":["D:\\Program Files (x86)\\Trae CN\\new file\\guide\\frontend\\src\\pages\\Food\\FoodView.vue"],"sourcesContent":["<template>\r\n  <div class=\"food-container\">\r\n    <el-card shadow=\"hover\" class=\"search-card\">\r\n      <template #header>\r\n        <div class=\"card-header\">\r\n          <span>美食推荐</span>\r\n        </div>\r\n      </template>\r\n      <el-form :inline=\"true\" :model=\"searchForm\" class=\"search-form\">\r\n        <el-form-item label=\"菜系\">\r\n          <el-select v-model=\"searchForm.cuisine\" placeholder=\"选择菜系\">\r\n            <el-option label=\"全部\" value=\"\"></el-option>\r\n            <el-option label=\"川菜\" value=\"sichuan\"></el-option>\r\n            <el-option label=\"粤菜\" value=\"cantonese\"></el-option>\r\n            <el-option label=\"鲁菜\" value=\"shandong\"></el-option>\r\n            <el-option label=\"淮扬菜\" value=\"huaiyang\"></el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n        <el-form-item>\r\n          <el-button type=\"primary\" @click=\"handleSearch\">搜索</el-button>\r\n        </el-form-item>\r\n      </el-form>\r\n    </el-card>\r\n\r\n    <div class=\"food-list\">\r\n      <el-card\r\n        v-for=\"food in foodList\"\r\n        :key=\"food.id\"\r\n        shadow=\"hover\"\r\n        class=\"food-card\"\r\n      >\r\n        <template #header>\r\n          <div class=\"food-header\">\r\n            <span>{{ food.name }}</span>\r\n            <div class=\"food-rating\">\r\n              <el-rate\r\n                v-model=\"food.rating\"\r\n                :max=\"5\"\r\n                disabled\r\n                show-score\r\n                score-template=\"{{ value }}\"\r\n              ></el-rate>\r\n            </div>\r\n          </div>\r\n        </template>\r\n        <div class=\"food-content\">\r\n          <p>{{ food.description }}</p>\r\n          <div class=\"food-info\">\r\n            <span class=\"cuisine\">{{ getCuisineName(food.cuisine) }}</span>\r\n            <span class=\"price\">价格: ¥{{ food.price }}</span>\r\n          </div>\r\n        </div>\r\n      </el-card>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'FoodView',\r\n  data() {\r\n    return {\r\n      searchForm: {\r\n        cuisine: ''\r\n      },\r\n      foodList: []\r\n    }\r\n  },\r\n  mounted() {\r\n    this.getFoodList()\r\n  },\r\n  methods: {\r\n    async getFoodList() {\r\n      try {\r\n        // 这里应该调用后端API，现在使用模拟数据\r\n        this.foodList = [\r\n          {\r\n            id: 1,\r\n            name: '麻婆豆腐',\r\n            description: '四川传统名菜，麻辣鲜香',\r\n            hotness: 90,\r\n            rating: 4.5,\r\n            cuisine: 'sichuan',\r\n            price: 38\r\n          },\r\n          {\r\n            id: 2,\r\n            name: '宫保鸡丁',\r\n            description: '经典川菜，酸甜可口',\r\n            hotness: 85,\r\n            rating: 4.3,\r\n            cuisine: 'sichuan',\r\n            price: 45\r\n          },\r\n          {\r\n            id: 3,\r\n            name: '糖醋里脊',\r\n            description: '酸甜可口，外酥里嫩',\r\n            hotness: 80,\r\n            rating: 4.2,\r\n            cuisine: 'shandong',\r\n            price: 58\r\n          }\r\n        ]\r\n      } catch (error) {\r\n        console.error('获取美食列表失败:', error)\r\n      }\r\n    },\r\n    async handleSearch() {\r\n      try {\r\n        // 这里应该调用后端API，现在使用模拟数据\r\n        this.foodList = [\r\n          {\r\n            id: 1,\r\n            name: '麻婆豆腐',\r\n            description: '四川传统名菜，麻辣鲜香',\r\n            hotness: 90,\r\n            rating: 4.5,\r\n            cuisine: 'sichuan',\r\n            price: 38\r\n          },\r\n          {\r\n            id: 2,\r\n            name: '宫保鸡丁',\r\n            description: '经典川菜，酸甜可口',\r\n            hotness: 85,\r\n            rating: 4.3,\r\n            cuisine: 'sichuan',\r\n            price: 45\r\n          }\r\n        ]\r\n      } catch (error) {\r\n        console.error('搜索失败:', error)\r\n      }\r\n    },\r\n    getCuisineName(cuisine) {\r\n      const cuisineMap = {\r\n        'sichuan': '川菜',\r\n        'cantonese': '粤菜',\r\n        'shandong': '鲁菜',\r\n        'huaiyang': '淮扬菜'\r\n      }\r\n      return cuisineMap[cuisine] || cuisine\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.food-container {\r\n  padding: 20px;\r\n}\r\n\r\n.search-card {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.search-form {\r\n  margin-top: 10px;\r\n}\r\n\r\n.food-list {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));\r\n  gap: 20px;\r\n}\r\n\r\n.food-card {\r\n  height: 100%;\r\n}\r\n\r\n.food-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n}\r\n\r\n.food-content {\r\n  margin-top: 10px;\r\n}\r\n\r\n.food-info {\r\n  margin-top: 15px;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  font-size: 14px;\r\n  color: #606266;\r\n}\r\n\r\n.cuisine {\r\n  color: #409eff;\r\n}\r\n\r\n.price {\r\n  color: #f56c6c;\r\n  font-weight: bold;\r\n}\r\n</style>"],"mappings":"AA0DA,eAAe;EACbA,IAAI,EAAE,UAAU;EAChBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,UAAU,EAAE;QACVC,OAAO,EAAE;MACX,CAAC;MACDC,QAAQ,EAAE;IACZ;EACF,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,WAAW,CAAC;EACnB,CAAC;EACDC,OAAO,EAAE;IACP,MAAMD,WAAWA,CAAA,EAAG;MAClB,IAAI;QACF;QACA,IAAI,CAACF,QAAO,GAAI,CACd;UACEI,EAAE,EAAE,CAAC;UACLR,IAAI,EAAE,MAAM;UACZS,WAAW,EAAE,aAAa;UAC1BC,OAAO,EAAE,EAAE;UACXC,MAAM,EAAE,GAAG;UACXR,OAAO,EAAE,SAAS;UAClBS,KAAK,EAAE;QACT,CAAC,EACD;UACEJ,EAAE,EAAE,CAAC;UACLR,IAAI,EAAE,MAAM;UACZS,WAAW,EAAE,WAAW;UACxBC,OAAO,EAAE,EAAE;UACXC,MAAM,EAAE,GAAG;UACXR,OAAO,EAAE,SAAS;UAClBS,KAAK,EAAE;QACT,CAAC,EACD;UACEJ,EAAE,EAAE,CAAC;UACLR,IAAI,EAAE,MAAM;UACZS,WAAW,EAAE,WAAW;UACxBC,OAAO,EAAE,EAAE;UACXC,MAAM,EAAE,GAAG;UACXR,OAAO,EAAE,UAAU;UACnBS,KAAK,EAAE;QACT,EACF;MACF,EAAE,OAAOC,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,WAAW,EAAEA,KAAK;MAClC;IACF,CAAC;IACD,MAAME,YAAYA,CAAA,EAAG;MACnB,IAA