{"ast":null,"code":"export default {\n  name: 'UserCenterView',\n  data() {\n    return {\n      defaultAvatar: '',\n      userInfo: {\n        username: 'admin',\n        name: '管理员',\n        phone: '13800138000',\n        email: 'admin@example.com'\n      }\n    };\n  },\n  mounted() {\n    this.getUserInfo();\n  },\n  methods: {\n    async getUserInfo() {\n      try {\n        // 这里应该调用后端API，现在使用模拟数据\n        this.userInfo = {\n          username: 'admin',\n          name: '管理员',\n          phone: '13800138000',\n          email: 'admin@example.com'\n        };\n      } catch (error) {\n        console.error('获取用户信息失败:', error);\n      }\n    },\n    handleLogout() {\n      sessionStorage.removeItem('token');\n      this.$router.push('/login');\n      this.$message.success('退出登录成功');\n    }\n  }\n};","map":{"version":3,"names":["name","data","defaultAvatar","userInfo","username","phone","email","mounted","getUserInfo","methods","error","console","handleLogout","sessionStorage","removeItem","$router","push","$message","success"],"sources":["E:\\北邮\\大二下\\数据结构\\project\\guide\\frontend\\src\\pages\\User\\UserCenterView.vue"],"sourcesContent":["<template>\r\n  <div class=\"user-center-container\">\r\n    <el-card shadow=\"hover\" class=\"user-card\">\r\n      <template #header>\r\n        <div class=\"card-header\">\r\n          <span>用户中心</span>\r\n        </div>\r\n      </template>\r\n      <div class=\"user-info\">\r\n        <div class=\"user-avatar\">\r\n          <el-avatar :size=\"100\" :src=\"userInfo.avatar || defaultAvatar\">\r\n            {{ userInfo.name?.charAt(0) || 'U' }}\r\n          </el-avatar>\r\n        </div>\r\n        <div class=\"user-details\">\r\n          <h3>{{ userInfo.name || '未设置' }}</h3>\r\n          <p><strong>用户名:</strong> {{ userInfo.username }}</p>\r\n          <p><strong>手机号:</strong> {{ userInfo.phone || '未设置' }}</p>\r\n          <p><strong>邮箱:</strong> {{ userInfo.email || '未设置' }}</p>\r\n        </div>\r\n      </div>\r\n      <div class=\"user-actions\">\r\n        <el-button type=\"primary\" @click=\"handleLogout\">退出登录</el-button>\r\n      </div>\r\n    </el-card>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'UserCenterView',\r\n  data() {\r\n    return {\r\n      defaultAvatar: '',\r\n      userInfo: {\r\n        username: 'admin',\r\n        name: '管理员',\r\n        phone: '13800138000',\r\n        email: 'admin@example.com'\r\n      }\r\n    }\r\n  },\r\n  mounted() {\r\n    this.getUserInfo()\r\n  },\r\n  methods: {\r\n    async getUserInfo() {\r\n      try {\r\n        // 这里应该调用后端API，现在使用模拟数据\r\n        this.userInfo = {\r\n          username: 'admin',\r\n          name: '管理员',\r\n          phone: '13800138000',\r\n          email: 'admin@example.com'\r\n        }\r\n      } catch (error) {\r\n        console.error('获取用户信息失败:', error)\r\n      }\r\n    },\r\n    handleLogout() {\r\n      sessionStorage.removeItem('token');\r\n      this.$router.push('/login');\r\n      this.$message.success('退出登录成功');\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.user-center-container {\r\n  padding: 20px;\r\n}\r\n\r\n.user-info {\r\n  display: flex;\r\n  align-items: center;\r\n  margin-bottom: 30px;\r\n}\r\n\r\n.user-avatar {\r\n  margin-right: 30px;\r\n}\r\n\r\n.user-details h3 {\r\n  margin: 0 0 15px 0;\r\n}\r\n\r\n.user-details p {\r\n  margin: 10px 0;\r\n  font-size: 16px;\r\n}\r\n\r\n.user-actions {\r\n  margin-top: 20px;\r\n}\r\n</style>"],"mappings":"AA6BA,eAAe;EACbA,IAAI,EAAE,gBAAgB;EACtBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,aAAa,EAAE,EAAE;MACjBC,QAAQ,EAAE;QACRC,QAAQ,EAAE,OAAO;QACjBJ,IAAI,EAAE,KAAK;QACXK,KAAK,EAAE,aAAa;QACpBC,KAAK,EAAE;MACT;IACF;EACF,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,WAAW,CAAC;EACnB,CAAC;EACDC,OAAO,EAAE;IACP,MAAMD,WAAWA,CAAA,EAAG;MAClB,IAAI;QACF;QACA,IAAI,CAACL,QAAO,GAAI;UACdC,QAAQ,EAAE,OAAO;UACjBJ,IAAI,EAAE,KAAK;UACXK,KAAK,EAAE,aAAa;UACpBC,KAAK,EAAE;QACT;MACF,EAAE,OAAOI,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,WAAW,EAAEA,KAA